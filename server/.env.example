# path: server/.env.example
# Copy this to server/.env and fill in your values.
# NEVER commit the real .env file to Git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local dev: mongodb://localhost:27017/neethivaan
# Atlas:     mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/neethivaan?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/neethivaan

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_very_long_random_secret_string_before_production
JWT_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app,https://your-app.netlify.app

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# For Gmail: enable 2FA + generate an App Password at
# https://myaccount.google.com/apppasswords
# TODO: Set real credentials before deploying
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Automation ────────────────────────────────────────────────────────────────
# Days before a 'Submitted' complaint is auto-escalated
AUTO_ESCALATE_DAYS=5

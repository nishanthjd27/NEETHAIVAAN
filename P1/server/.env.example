# ─────────────────────────────────────────────────────────────────
# NEETHIVAAN – Environment Variables
# Copy this file:  cp .env.example .env
# Fill in your real values in .env
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local:   mongodb://localhost:27017/neethivaan
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/neethivaan
MONGODB_URI=mongodb://localhost:27017/neethivaan

# JWT
# Generate secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_long_random_jwt_secret_minimum_32_characters
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# CORS  (comma-separated list of allowed frontend origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email  (Gmail SMTP — create App Password at myaccount.google.com/apppasswords)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Client URL  (used in password-reset emails)
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
